#include <stdio.h>
#include <string.h>

int main() {
    char text[100], key[100];
    int i;

    printf("Enter plaintext (uppercase): ");
    scanf("%s", text);

    printf("Enter key (uppercase): ");
    scanf("%s", key);

    int keyLen = strlen(key);

    for(i = 0; text[i] != '\0'; i++) {
        text[i] = ((text[i]-'A') + (key[i % keyLen]-'A')) % 26 + 'A';
    }

    printf("Ciphertext: %s\n", text);

    return 0;
}
